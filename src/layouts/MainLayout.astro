---
const { title } = Astro.props;
---
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>{title}</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@picocss/pico@2/css/pico.min.css">
    <style>
        :root { --primary: #ff8fab; /* A soft professional pink */ }
        body { padding: 40px 20px; max-width: 800px; margin: auto; }
        nav { margin-bottom: 3rem; }
        /* Cute rounded corners on everything */
        article, ins, mark, button { border-radius: 16px !important; }
        a { text-decoration: none; font-weight: 600; }
    </style>
</head>
<body>
    <nav>
        <ul><li><strong>Natalia</strong></li></ul>
        <ul>
            <li><a href="/personal-site/">Home</a></li>
            <li><a href="/personal-site/resume">Resume</a></li>
        </ul>
    </nav>
    
    <main>
        <slot /> </main>
    
    <footer style="margin-top: 5rem; font-size: 0.8rem; opacity: 0.6;">
        © {new Date().getFullYear()} Natalia
    </footer>
</body>
</html>
