---
const name = "Natalia";
const education = "William & Mary, Economics Major";
const interests = ["Lifting", "Movies", "Music"];
---
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>{name}'s Portfolio</title>
    <style>
        body { font-family: system-ui, sans-serif; max-width: 800px; margin: 40px auto; padding: 20px; line-height: 1.6; color: #333; }
        nav { margin-bottom: 40px; border-bottom: 1px solid #eaeaea; padding-bottom: 20px; }
        nav a { margin-right: 20px; text-decoration: none; color: #0070f3; font-weight: 600; }
        .hero { background: #f9f9f9; padding: 20px; border-radius: 8px; border: 1px solid #eee; }
    </style>
</head>
<body>
    <nav>
        <a href="/personal-site/">Home</a>
        <a href="/personal-site/resume">Resume</a>
        <a href="/personal-site/posts/hello">Blog Post</a>
    </nav>

    <div class="hero">
        <h1>Hi, I'm {name} 👋</h1>
        <p><strong>Education:</strong> {education}</p>
    </div>

    <h2>My Interests</h2>
    <ul>
        {interests.map((item) => <li>{item}</li>)}
    </ul>
</body>
</html>
